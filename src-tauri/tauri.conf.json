{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Desktop Companion",
  "version": "0.1.0",
  "identifier": "com.shiroenguyen.desktop-companion",
  "build": {
    "frontendDist": "../app"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "Desktop Companion",
    "category": "Productivity",
    "shortDescription": "Live2D desktop pet with AI translate / reply / tasks",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
